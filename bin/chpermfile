#!/bin/bash

BLACK=$'\033[30m'
RED=$'\033[31m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'
BLUE=$'\033[34m'
MAGNETA=$'\033[35m'
CYAN=$'\033[36m'
WHITE=$'\033[37m'

BGBLACK=$'\033[40m'
BGRED=$'\033[41m'
BGGREEN=$'\033[42m'
BGYELLOW=$'\033[43m'
BGBLUE=$'\033[44m'
BGMAGNETA=$'\033[45m'
BGCYAN=$'\033[46m'
BGWHITE=$'\033[47m'

BRIGHT=$'\033[01m'
NORMAL=$'\033[00m'

UNDERSCORE=$'\033[04m'
BLINK=$'\033[05m'
REVERSE=$'\033[07m'

echo $REVERSE$GREEN"Este comando cambia los permisos de los archivos"$NORMAL
echo $REVERSE$GREEN"en $(pwd) recursivamente"$NORMAL
echo $REVERSE$GREEN"Asigna permisos 644, es decir, rw-r--r--"$NORMAL
echo $REVERSE$RED'Sigue? s/n:'$NORMAL
read opcion

case $opcion in

    s) find . -type f -exec chmod -R 644 {} \; ;;
    *) ;;

esac
